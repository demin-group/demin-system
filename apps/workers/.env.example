# ─────────────────────────────────────────────────────────────────────────────
# apps/workers/.env.example
#
# Plantilla de variables para los workers Python de DEMIN. Copiar a
# .env.dev o .env.prod (ambos gitignored) y rellenar los placeholders <...>
# con valores reales tomados de Bitwarden. Nunca commitear los .env reales.
#
# Regla nº 5 del Apéndice A de tasks/todo.md: variables de entorno o
# Supabase Vault, jamás credenciales hardcoded en el código.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL del proyecto (demin-dev o demin-prod). Formato:
# https://<project-ref>.supabase.co
SUPABASE_URL=<URL del proyecto Supabase — Project Settings > API>

# Secret key (antes "service role key"). Bypass de RLS, server-side only.
SUPABASE_SERVICE_ROLE_KEY=<secret key — Bitwarden item "demin-supabase-{dev|prod}-service-role">

# Connection string Postgres directo para SQLAlchemy / psycopg. Incluye
# password de la BD. Formato:
# postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=<postgres:// con password — Bitwarden item "demin-supabase-{dev|prod}-db-url">

# Discriminador de entorno. Valores válidos: dev | prod.
SUPABASE_ENV=<dev|prod>

# ── Anthropic ───────────────────────────────────────────────────────────────
# API key. Coste cargado a $25 de créditos iniciales (ver Lección 3).
ANTHROPIC_API_KEY=<sk-ant-... — Bitwarden item "demin-anthropic-api-key">

# Modelo por tarea (mapeo MODEL_FOR_TASK — ver apps/workers/shared/llm.py).
# Cualquier worker DEBE leer estos envs, NUNCA hardcodear el modelo (Lección 3).
# Notas sobre formato de model ID:
#   - Haiku se distribuye dated obligatoriamente (no hay alias plano estable).
#   - Sonnet usa alias plano hasta que Anthropic publique un dated estable;
#     entonces se pinea aquí en .env.prod.
ANTHROPIC_MODEL_CLASSIFY_DESCR=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_RESEARCH=claude-sonnet-4-6
ANTHROPIC_MODEL_GENERATE_DRAFT=claude-sonnet-4-6
ANTHROPIC_MODEL_CLASSIFY_REPLY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SUGGEST_RESPONSE=claude-sonnet-4-6

# ── Voyage AI (embeddings del KB) ───────────────────────────────────────────
VOYAGE_API_KEY=<API key — Bitwarden item "demin-voyage-api-key">
VOYAGE_MODEL=voyage-multilingual-2
VOYAGE_EMBEDDING_DIM=1024

# ── Apollo (Fase 1, enriquecimiento Tier 4) ─────────────────────────────────
# TODO Fase 1: dar de alta plan Basic y rellenar.
APOLLO_API_KEY=<API key — Bitwarden item "demin-apollo-api-key" (pendiente Fase 1)>

# ── Gmail OAuth (Fase 2, envío real) ────────────────────────────────────────
# OAuth client se crea en Fase 2 (A6 del Bloque A diferido). Hasta entonces
# placeholders.
GMAIL_OAUTH_CLIENT_ID=<OAuth Client ID — Bitwarden (pendiente Fase 2)>
GMAIL_OAUTH_CLIENT_SECRET=<OAuth Client Secret — Bitwarden (pendiente Fase 2)>

# Refresh token: 1 por buzón. En PRODUCCIÓN vive en BD cifrado vía Supabase
# Vault (campo mailboxes.oauth_refresh_token_encrypted), NO en este .env. Esta
# variable solo se usa en desarrollo local cuando se quiere probar contra un
# buzón de prueba propio del desarrollador.
GMAIL_OAUTH_REFRESH_TOKEN=<refresh token de buzón de prueba — solo dev local>

# ── Mailbox config (Lección 4) ──────────────────────────────────────────────
SENDING_MAILBOX_EMAIL=gonzalo.perez@demingroupmadrid.com
SENDING_MAILBOX_DISPLAY_NAME=Gonzalo Pérez
SENDING_DOMAIN=demingroupmadrid.com

# ── Postmaster Tools ────────────────────────────────────────────────────────
POSTMASTER_DOMAIN=demingroupmadrid.com
