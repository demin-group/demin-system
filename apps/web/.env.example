# ─────────────────────────────────────────────────────────────────────────────
# apps/web/.env.example
#
# Plantilla de variables para el sitio público (demingroupmadrid.com).
# El sitio es estático en su mayoría; solo el route handler /api/contact
# necesita acceso a Supabase para insertar en web_leads y disparar email
# de aviso a Gonzalo.
#
# Copiar a .env.dev / .env.prod (gitignored) y rellenar. Nunca commitear los
# .env reales. Regla nº 5 del Apéndice A: variables de entorno o Supabase Vault.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=<URL del proyecto — Project Settings > API>

# Publishable key (antes "anon key"). El widget de cliente la usa.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable key — Bitwarden item "demin-supabase-{dev|prod}-publishable">

# Secret key. Solo para el route handler /api/contact (Node runtime, no Edge),
# que escribe en web_leads con bypass de RLS — el visitante del sitio público
# no está autenticado, así que necesitamos service role para el insert.
SUPABASE_SERVICE_ROLE_KEY=<secret key — Bitwarden item "demin-supabase-{dev|prod}-service-role">

# CONTACT_NOTIFICATION_EMAIL — destino de los emails de aviso de leads inbound desde el formulario.
# Prod (Vercel): gonzalo.perez@demingroupmadrid.com
# Local/dev: ídem (acuerdo con Alberto: máx. 1-2 envíos de prueba para no afectar al warmup activo de Lemwarm).
CONTACT_NOTIFICATION_EMAIL=

# ── Resend — notificación de leads inbound desde el formulario ─────────────
# Generar key en https://resend.com/api-keys con permiso "sending access".
# Sin esto, los leads se siguen guardando en web_leads pero no se envía aviso
# (best-effort: el route handler loguea el warning y devuelve 200 igualmente).
RESEND_API_KEY=

# Remitente del email de notificación. Debe usar dominio verificado en Resend.
# En Resend tenemos verificado el dominio raíz demingroupmadrid.com (no el subdominio).
# Aunque el remitente visible es @demingroupmadrid.com, los DNS records dejan SPF/MX
# en send.demingroupmadrid.com, por lo que la reputación de envío sigue aislada del
# Workspace de Gonzalo. No usar @send.demingroupmadrid.com aquí: la API key está
# restringida al dominio raíz y rechazaría el envío con 403.
CONTACT_FROM_EMAIL=DEMIN Group <noreply@demingroupmadrid.com>

# ── Identidad del sitio ─────────────────────────────────────────────────────
# Origen canónico del sitio. Se usa en metadata SEO (canonical, OG) y en el
# JSON-LD de Schema.org. En dev déjalo en http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://demingroupmadrid.com
