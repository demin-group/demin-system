# ─────────────────────────────────────────────────────────────────────────────
# apps/web/.env.example
#
# Plantilla de variables para el sitio público (demingroupmadrid.com).
# El sitio es estático en su mayoría; solo el route handler /api/contact
# necesita acceso a Supabase para insertar en web_leads y disparar email
# de aviso a Gonzalo.
#
# Copiar a .env.dev / .env.prod (gitignored) y rellenar. Nunca commitear los
# .env reales. Regla nº 5 del Apéndice A: variables de entorno o Supabase Vault.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=<URL del proyecto — Project Settings > API>

# Publishable key (antes "anon key"). El widget de cliente la usa.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable key — Bitwarden item "demin-supabase-{dev|prod}-publishable">

# Secret key. Solo para el route handler /api/contact (Node runtime, no Edge),
# que escribe en web_leads con bypass de RLS — el visitante del sitio público
# no está autenticado, así que necesitamos service role para el insert.
SUPABASE_SERVICE_ROLE_KEY=<secret key — Bitwarden item "demin-supabase-{dev|prod}-service-role">

# ── Notificación del formulario de contacto ─────────────────────────────────
# Buzón al que se manda el aviso "nuevo lead inbound" cuando alguien rellena
# el formulario de contacto. En dev conviene apuntar a tu propio email para
# no bombardear a Gonzalo con submissions de prueba.
CONTACT_NOTIFICATION_EMAIL=gonzalo.perez@demingroupmadrid.com
