# ─────────────────────────────────────────────────────────────────────────────
# apps/dashboard/.env.example
#
# Plantilla de variables para el panel autenticado (app.demingroupmadrid.com).
# Copiar a .env.dev / .env.prod (gitignored) y rellenar los placeholders <...>
# con valores reales de Bitwarden. Nunca commitear los .env reales.
#
# Regla nº 5 del Apéndice A: variables de entorno o Supabase Vault.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (cliente público + servidor) ───────────────────────────────────
# URL del proyecto Supabase (demin-dev o demin-prod). NEXT_PUBLIC_* expuesta
# al navegador, segura porque es solo el endpoint.
NEXT_PUBLIC_SUPABASE_URL=<URL del proyecto — Project Settings > API>

# Publishable key (antes "anon key"). El cliente del navegador la usa para
# auth y queries con RLS aplicada. Segura para exponer.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable key — Bitwarden item "demin-supabase-{dev|prod}-publishable">

# Secret key (antes "service role key"). Server-side only — Server Actions y
# Route Handlers que necesiten bypass de RLS. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=<secret key — Bitwarden item "demin-supabase-{dev|prod}-service-role">

# ── Configuración pública del dashboard ─────────────────────────────────────
# URL canónica del dashboard. Se usa para construir links absolutos en correos
# de magic link y redirecciones de OAuth. En dev típicamente
# http://localhost:3000; en prod https://app.demingroupmadrid.com.
NEXT_PUBLIC_APP_URL=<URL del dashboard según entorno — http://localhost:3000 en dev, https://app.demingroupmadrid.com en prod>

# ── Auth allowlist (B3) ─────────────────────────────────────────────────────
# Lista blanca de emails que pueden iniciar sesión. CSV sin espacios. El
# middleware de B3 compara contra session.user.email; cualquier otro email
# recibe logout + redirect a /login?error=unauthorized.
ALLOWED_EMAILS=<lista CSV de emails autorizados — p.ej. albertobueno10@gmail.com,gonzalo.perez@demingroupmadrid.com>
